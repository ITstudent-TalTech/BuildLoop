# BUILDLoop Backend — Environment Variables
# Copy this file to app/.env.local and fill in real values.
# app/.env.local is gitignored; never commit actual secrets.
#
# Usage:
#   cp app/.env.example app/.env.local
#   # edit app/.env.local with real credentials
#   cd app && alembic upgrade head

# ---------------------------------------------------------------------------
# Database
# Full async connection URL using the asyncpg driver.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# For Supabase: use the "Transaction" pooler connection string from the
# project dashboard (Settings → Database → Connection Pooling), then swap
# the scheme to postgresql+asyncpg.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# Test database (separate project or local Postgres — never the real Supabase)
# Required for running the test suite; tests fail to start if unset.
# ---------------------------------------------------------------------------
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/buildloop_test

# ---------------------------------------------------------------------------
# Supabase
# Find these in Supabase dashboard → Settings → API.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Storage bucket names
# Create these buckets manually in the Supabase dashboard → Storage.
# The defaults below match the bucket names the code expects.
# ---------------------------------------------------------------------------
SUPABASE_STORAGE_SOURCE_BUCKET=source-documents
SUPABASE_STORAGE_PASSPORT_BUCKET=published-passports

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
ENV=dev
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Resolver — In-ADS gazetteer (Estonian address register, public API)
# ---------------------------------------------------------------------------
# Base URL for the In-ADS REST API. Change only if using a local mirror.
RESOLVER_INADS_BASE_URL=https://inaadress.maaamet.ee/inaadress
# Feature layers to request. Controls which object types appear in results.
RESOLVER_INADS_FEATURES=EHAK,VAIKEKOHT,TANAV,KATASTRIYKSUS,EHITISHOONE
# Set to false in environments with correct PKI. When true the resolver retries
# once without TLS verification after an SSL handshake error — a known workaround
# for Estonian network paths with incomplete certificate chains.
RESOLVER_INADS_SSL_FALLBACK=true
# Confidence score threshold for automatic resolution (no candidate selection needed).
RESOLVER_AUTO_RESOLVE_THRESHOLD=0.85
# Confidence score threshold above which the result is ambiguous (vs. unresolved).
RESOLVER_AMBIGUOUS_THRESHOLD=0.50
# Semver stamped on every address_resolution_runs row for regression tracking.
RESOLVER_VERSION=v1.0.0

# ---------------------------------------------------------------------------
# Source ingestion — EHR PDF fetch (Session 2.3)
# ---------------------------------------------------------------------------
# Base URL for the Estonian EHR document API.
INGEST_EHR_BASE_URL=https://livekluster.ehr.ee/api/document/v1
# Set to false in environments with correct PKI. When true the fetcher retries
# once without TLS verification after an SSL handshake error.
INGEST_EHR_SSL_FALLBACK=true
# HTTP timeout per fetch attempt in seconds.
# Note: the reference script (buildloop_passport_from_address.py line 346) uses 90s.
# This setting defaults to 60s per session spec. See TODO(2.3 review) in ehr_fetcher.py.
INGEST_EHR_TIMEOUT_SECONDS=60
