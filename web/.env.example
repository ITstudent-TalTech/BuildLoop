# Artificial network delay for mock API calls
MOCK_DELAY_MS=500

# Resolution mode: 'resolved' | 'ambiguous' | 'unresolved'
# Controls what mockResolveAddress returns for testing all three flow branches.
MOCK_RESOLUTION_MODE=resolved

# Draft variant: 'complete' | 'partial' | 'sparse'
# Controls which fixture mockGetPassportDraft returns.
MOCK_DRAFT_VARIANT=complete

# Optional: force the next API call to fail
# Format: status:code:message
# Example: 503:server_unavailable:Database is down
# MOCK_FAIL_NEXT=
